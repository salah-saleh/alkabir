# Secrets defined here are available for reference under registry/password,
# env/secret, and builder/secrets in config/deploy.yml. All secrets should be
# pulled from either a password manager, ENV, or a file. DO NOT ENTER RAW
# CREDENTIALS HERE! This file needs to be safe for git.
#
# In CI (GitHub Actions), this is populated from the built-in GITHUB_TOKEN by
# .github/workflows/deploy.yml. Locally, export the same var in your shell
# before running bin/kamal deploy by hand.

# GHCR auth: a GitHub PAT (classic or fine-grained) with read:packages/write:packages,
# or in CI, the built-in GITHUB_TOKEN.
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD
